# DeepSeek server-side key. Do not expose this in frontend code.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# Optional: improves local Xiaohongshu link parsing.
# Copy from Chrome DevTools > Application > Cookies > xiaohongshu.com.
# XHS_COOKIE_STRING=a1=VALUE; web_session=VALUE
XHS_COOKIE_STRING=
